{
  "brand": {
    "primary": "#C45A3B",
    "accent": "#E07B5A"
  },
  "color": {
    "primary": { "light": "#B25134", "dark": "#E07B5A" },
    "onPrimary": { "light": "#FAF9F5", "dark": "#12171F" },
    "primaryContainer": { "light": "#F0D5CC", "dark": "#4A2318" },
    "onPrimaryContainer": { "light": "#2C2416", "dark": "#F0D5CC" },
    "surface": { "light": "#FAF9F5", "dark": "#12171F" },
    "onSurface": { "light": "#2C2416", "dark": "#EDE6DA" },
    "error": { "light": "#A84444", "dark": "#D46A6A" },
    "onError": { "light": "#FAF9F5", "dark": "#12171F" }
  },
  "spacing": {
    "xs": 4,
    "sm": 8,
    "md": 12,
    "lg": 16,
    "xl": 24
  },
  "radius": {
    "sm": 4,
    "md": 8,
    "lg": 12,
    "round": 999
  },
  "elevation": {
    "none": {
      "dp": 0,
      "shadow": {
        "light": [{ "x": 0, "y": 0, "blur": 0, "spread": 0, "color": "#000000", "opacity": 0 }],
        "dark": [{ "x": 0, "y": 0, "blur": 0, "spread": 0, "color": "#000000", "opacity": 0 }]
      }
    },
    "sm": {
      "dp": 1,
      "shadow": {
        "light": [{ "x": 0, "y": 1, "blur": 3, "spread": 0, "color": "#000000", "opacity": 0.12 }],
        "dark": [{ "x": 0, "y": 1, "blur": 3, "spread": 0, "color": "#000000", "opacity": 0.24 }]
      }
    }
  },
  "shadowCard": {
    "light": [{ "x": 0, "y": 2, "blur": 8, "spread": 0, "color": "#000000", "opacity": 0.08 }],
    "dark": [{ "x": 0, "y": 2, "blur": 8, "spread": 0, "color": "#000000", "opacity": 0.16 }]
  },
  "iconSize": {
    "sm": 18,
    "md": 22,
    "lg": 28
  },
  "typography": {
    "provider": "asset",
    "fontFamily": {
      "display": "Merriweather",
      "body": "Merriweather"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semiBold": 600,
      "bold": 700
    },
    "scale": {
      "displayLarge": { "size": 57, "weight": "regular", "family": "display" },
      "bodyMedium": { "size": 14, "weight": "regular", "family": "body" },
      "labelSmall": { "size": 11, "weight": "medium", "family": "body" }
    }
  },
  "extensions": {
    "AppColors": {
      "_getter": "appColors",
      "brand": { "light": "#C45A3B", "dark": "#E07B5A" },
      "success": { "light": "#4A5D4A", "dark": "#6A906A" }
    },
    "GenreColors": {
      "mystery": { "light": "#4A5D6A", "dark": "#6A8090" },
      "horror": { "light": "#5A3A3A", "dark": "#8A5A5A" }
    }
  }
}
