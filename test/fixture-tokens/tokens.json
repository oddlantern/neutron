        "light": [
          { "x": 0, "y": 8, "blur": 12, "spread": 6, "color": "#2C2416", "opacity": 0.08 },
          { "x": 0, "y": 4, "blur": 4, "spread": 0, "color": "#2C2416", "opacity": 0.1 }
