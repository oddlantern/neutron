{
  "name": "@oddlantern/mido",
  "version": "0.0.12",
  "description": "Cross-ecosystem monorepo workspace tool",
  "type": "module",
  "bin": {
    "mido": "./dist/bin.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepare": "mido install"
  },
  "keywords": [
    "monorepo",
    "workspace",
    "cross-ecosystem",
    "typescript",
    "dart",
    "flutter",
    "consistency"
  ],
  "author": "Odd Lantern",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddlantern/mido"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsdown": "^0.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
