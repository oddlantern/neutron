{
  "name": "@oddlantern/mido",
  "version": "1.5.0",
  "description": "Cross-ecosystem monorepo workspace tool",
  "type": "module",
  "bin": {
    "mido": "dist/bin.js"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "generate:schema": "tsx scripts/generate-schema.ts",
    "build": "tsx scripts/generate-schema.ts && tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepare": "node dist/bin.js install"
  },
  "keywords": [
    "monorepo",
    "workspace",
    "cross-ecosystem",
    "typescript",
    "dart",
    "flutter",
    "consistency"
  ],
  "author": "Odd Lantern",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oddlantern/mido.git"
  },
  "homepage": "https://github.com/oddlantern/mido#readme",
  "bugs": {
    "url": "https://github.com/oddlantern/mido/issues"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chokidar": "^4.0.3",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@elysiajs/openapi": "^1.4.14",
    "elysia": "^1.4.28",
    "tsdown": "^0.14.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
